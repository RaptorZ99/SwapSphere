{
  "name": "@swapsphere/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "pnpm prisma:generate",
    "dev": "tsx watch src/server.ts",
    "prebuild": "pnpm prisma:generate",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\" \"prisma.config.ts\" \"prisma/seed.ts\"",
    "precheck-types": "pnpm prisma:generate",
    "check-types": "tsc -p tsconfig.json --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "prisma:seed:if-empty": "tsx prisma/seed-if-empty.ts"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/adapter-pg": "7.4.1",
    "@prisma/client": "7.4.1",
    "@swapsphere/shared-types": "workspace:*",
    "@swapsphere/shared-utils": "workspace:*",
    "express": "5.2.1",
    "pg": "8.18.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@swapsphere/config-eslint": "workspace:*",
    "@swapsphere/config-typescript": "workspace:*",
    "@types/express": "^5.0.5",
    "@types/node": "^24.10.0",
    "@types/pg": "8.16.0",
    "dotenv": "^17.2.3",
    "eslint": "10.0.2",
    "prisma": "7.4.1",
    "tsx": "^4.20.6",
    "typescript": "5.9.3"
  }
}
